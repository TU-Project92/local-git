{
  "_version": "1.82.0",
  "sap.app": {
    "id": "com.example.project.frontend.frontend",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json"
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.example.project.frontend.frontend.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.ui.unified": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.example.project.frontend.frontend.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlId": "app",
        "controlAggregation": "pages",
        "viewType": "XML",
        "viewPath": "com.example.project.frontend.frontend.view",
        "async": true
      },
      "routes": [
        {
          "name": "RouteLogin",
          "pattern": "",
          "target": "TargetLogin"
        },
        {
          "name": "RouteRegister",
          "pattern": "register",
          "target": "TargetRegister"
        },
        {
          "name": "RouteDashboard",
          "pattern": "dashboard",
          "target": "TargetDashboard"
        },
        {
          "name": "RouteCreateDocument",
          "pattern": "documents/create",
          "target": "TargetCreateDocument"
        },
        {
          "name": "RouteDocumentDetails",
          "pattern": "documents/{documentId}",
          "target": "TargetDocumentDetails"
        }
      ],
      "targets": {
        "TargetLogin": {
          "viewName": "Login",
          "viewId": "Login"
        },
        "TargetRegister": {
          "viewName": "Register",
          "viewId": "Register"
        },
        "TargetDashboard": {
          "viewName": "Dashboard",
          "viewId": "Dashboard"
        },
        "TargetCreateDocument": {
          "viewName": "CreateDocument",
          "viewId": "CreateDocument"
        },
        "TargetDocumentDetails": {
          "viewName": "DocumentDetails",
          "viewId": "DocumentDetails"
        }
      }
    }
  }
}